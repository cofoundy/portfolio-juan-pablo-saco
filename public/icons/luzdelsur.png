                                <a href="/es/PagarRecibo" class="text-black font-24" onclick="trackClick(event, 'pagar recibo'); sendEventButtons('Ver mi recibo y pagar','Pagar mi recibo');"><i class="fa-solid fa-chevron-right"></i></a>
