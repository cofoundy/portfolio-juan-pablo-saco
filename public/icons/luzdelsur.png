<script>
    (function() {
        function getCookie(name) {
            var nameEQ = name + "=";
            var ca = document.cookie.split(';');
            for(var i=0;i < ca.length;i++) {
                var c = ca[i];
                while (c.charAt(0)==' ') c = c.substring(1,c.length);
                if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length,c.length);
            }
            return null;
        }

        document.addEventListener("DOMContentLoaded", function () {
            var wrapper = document.getElementById('consent-wrapper');
            var bannerInic = document.getElementById('banner-inicial');
            var modalConf = document.getElementById('modal-config');
            var cookieData = getCookie("consent_status");

            let _estado="";

            if (!cookieData) {
                wrapper.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            } else {
                try {
                    var data = JSON.parse(decodeURIComponent(cookieData));
                    gtag('consent', 'update', {
                        'analytics_storage': data.analytics,
                        'ad_storage': data.marketing,
                        'ad_user_data': data.marketing,
                        'ad_personalization': data.marketing
                    });
                } catch (e) {
                    wrapper.style.display = 'flex';
                }
            }

            // Clic fuera del modal retorna al banner
            wrapper.onclick = function(e) {
                if (e.target === wrapper && modalConf.style.display === 'block') {
                    modalConf.style.display = 'none';
                    bannerInic.style.display = 'flex';
                }
            };

           document.getElementById('btn-open-modal').onclick = function() {
                document.getElementById('toggle-analytics').checked = true;
                document.getElementById('toggle-marketing').checked = true;

                bannerInic.style.display = 'none';
                modalConf.style.display = 'block';
            };

            document.getElementById('btn-accept-all').onclick = function() {
                _estado="granted";
                procesarConsentimiento('granted', 'granted');
            };

            document.getElementById('btn-reject-all').onclick = function() {
                _estado="denied";
                procesarConsentimiento('denied', 'denied');
            };

            document.getElementById('btn-save-settings').onclick = function() {
                _estado="configuration";
                var aStatus = document.getElementById('toggle-analytics').checked ? 'granted' : 'denied';
                var mStatus = document.getElementById('toggle-marketing').checked ? 'granted' : 'denied';
                procesarConsentimiento(aStatus, mStatus);
            };

            function procesarConsentimiento(aStatus, mStatus) {
                gtag('consent', 'update', {
                    'analytics_storage': aStatus,
                    'ad_storage': mStatus,
                    'ad_user_data': mStatus,
                    'ad_personalization': mStatus
                });

                var cookieVal = JSON.stringify({ analytics: aStatus, marketing: mStatus });
                document.cookie = "consent_status=" + encodeURIComponent(cookieVal) + ";max-age=31536000;path=/";

                if(_estado=="granted")
                {
                    window.dataLayer.push({
                        'event': 'cookie_interaction',
                        'cookie_action': 'accept_all',
                        'cookie_type': 'banner',
                        'consent_analytics': aStatus,
                        'consent_marketing': mStatus
                    });

                    console.log("event:cookie_interaction");
                    console.log("cookie_action:accept_all");
                    console.log("cookie_type:banner");
                    console.log("consent_analytics:",aStatus);
                    console.log("consent_marketing:",mStatus);

                }
                else if(_estado=="denied")
                {
                    window.dataLayer.push({
                        'event': 'cookie_interaction',
                        'cookie_action': 'reject_all',
                        'cookie_type': 'modal',
                        'consent_analytics': aStatus,
                        'consent_marketing': mStatus
                    });

                    console.log("event:cookie_interaction");
                    console.log("cookie_action:reject_all");
                    console.log("cookie_type:modal");
                    console.log("consent_analytics:",aStatus);
                    console.log("consent_marketing:",mStatus);
                }
                else
                {
                    window.dataLayer.push({
                        'event': 'cookie_interaction',
                        'cookie_action': 'save_settings',
                        'cookie_type': 'modal',
                        'consent_analytics': aStatus,
                        'consent_marketing': mStatus
                    });

                    console.log("event:cookie_interaction");
                    console.log("cookie_action:save_settings");
                    console.log("cookie_type:modal");
                    console.log("consent_analytics:",aStatus);
                    console.log("consent_marketing:",mStatus);
                }

                // window.dataLayer.push({
                //     'event': 'cookie_interaction',
                //     'cookie_action': 'save_settings',
                //     'consent_analytics': aStatus,
                //     'consent_marketing': mStatus
                // });

                wrapper.style.display = 'none';
                document.body.style.overflow = 'visible';


                if (typeof muestraMensajeInicioCorporativa !== "undefined" && muestraMensajeInicioCorporativa.toLowerCase() === "true" && window.location.pathname==="/InformacionCorporativa") {
                    setTimeout(function () {
                        $("#modalMensajeInicio").modal("show");
                    }, 300);
                }

                if (typeof muestraMensajeHome !== "undefined" && muestraMensajeHome.toLowerCase() === "true" && (window.location.pathname==="/" || window.location.pathname==="/Home")) {
                    setTimeout(function () {
                        $("#modalMensajeInicio").modal("show");
                    }, 300);
                }
            }
        });
    })();
</script>
