<script>
    document.addEventListener("DOMContentLoaded", function () {
        const modal = document.getElementById("login_password");
        let eventDispatched = false;

        const observer = new MutationObserver(() => {
            const isVisible = modal.classList.contains("show") && getComputedStyle(modal).display === "block";

            if (isVisible && !eventDispatched) {
                eventDispatched = true;

               var dataLayer = window.dataLayer = window.dataLayer || [];
                dataLayer.push({
                    event: 'view_promotion',
                    TipoEvento: 'visualización',
                    TipoElemento: 'Pop Up',
                    Flujo: 'Olvide mi Contraseña',
                    TipoAcceso: 'login_password',
                    Zona: 'Olvide mi Contraseña',
                    SubZona: 'Restablece tu contraseña fácilmente',
                    CTA: undefined,
                    page_title: 'Olvide Contraseña - ingreso'
                });
            }
        });

        observer.observe(modal, {
            attributes: true,
            attributeFilter: ['class', 'style'],
            subtree: false
        });
    });
</script>

