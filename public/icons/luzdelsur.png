<script>
    $(document).ready(function () {
        sendEventLogin({
            evento: 'login_status',
            estado: 'Web p\u00FAblica',
            user_id: undefined
        });
    });

    function sendEventLogin({ evento, estado, user_id }) {
        var dataLayer = window.dataLayer = window.dataLayer || [];
        dataLayer.push({
            event: evento,
            Login_Status: estado,
            user_id: user_id,
            Version: '1.0',
            Plataforma: 'Web'
        });
    }
</script>
